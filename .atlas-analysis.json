  "keyFeatures": [
    "Modular voice AI plugin system with Python SDK",
    "Multiple ability types: Skills, Background Daemons, and Local",
    "Complete I/O control: TTS, speech-to-text, audio playback/recording",
    "LLM integration for text generation and conversation context",
    "8+ official abilities and 50+ community contributions",
    "Template library with patterns for common use cases",
    "WebSocket communication and local command execution",
    "File storage for persistent state and IPC"
  ],
